APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# After deploy: php artisan storage:link (recommended). Project images also load via /media/projects/… if /storage returns 403.
# If uploads 403: chmod -R ug+rX storage bootstrap/cache && chown -R www-data:www-data storage (adjust user for your host)

# Set to true to show only the Coming Soon page on all web routes (no artisan down needed)
COMING_SOON=false

# Admin panel password (default: admin)
ADMIN_PASSWORD=admin

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Microsoft 365 example: MAIL_MAILER=smtp, MAIL_HOST=smtp.office365.com, MAIL_PORT=587, MAIL_SCHEME=null (STARTTLS)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Optional recipient for contact form (defaults to MAIL_FROM_ADDRESS)
MAIL_TO_ADDRESS=

# Optional PDF attached to every website lead email (path inside storage/app, or public/..., or absolute path).
# Values with spaces MUST be in double quotes (or the .env file will not parse).
# Put the file at storage/app/lead-email/yourfile.pdf then set e.g. MAIL_LEAD_PDF=lead-email/yourfile.pdf
# If MAIL_LEAD_PDF is empty, no brochure is attached (only the visitor upload, if any).
MAIL_LEAD_PDF=
MAIL_LEAD_PDF_NAME="KSB Homes - Project guide.pdf"
# If uploads fail silently: raise PHP upload_max_filesize and post_max_size above 15M in php.ini

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
